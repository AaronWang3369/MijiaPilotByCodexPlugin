# Copy to a local shell profile, .env file, or Codex MCP environment.
# Do not commit the copied file if it contains real secrets.

# Base API URL of the running mijia-control Flask service.
MIJIA_API_URL=http://127.0.0.1:5000/api

# JWT access token issued by mijia-control.
# Obtain it with `mijia-control login` or the upstream /auth/jwt/login API.
MIJIA_TOKEN=replace-with-local-jwt-access-token

# Upstream mcp_server defaults to stdio. Keep stdio for Codex.
MCP_TRANSPORT=stdio
